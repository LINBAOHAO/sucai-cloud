# PostgreSQL (Prisma)
# Local dev:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sucai_cloud?schema=public"
#
# Supabase (recommended for Prisma db push — use Direct connection, port 5432):
# Dashboard → Project Settings → Database → Connection string → URI → Direct connection
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
# or host: db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sucai_cloud?schema=public"

# Admin dashboard credentials (required in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Supabase Storage (product images)
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
# Dashboard → Project Settings → API → service_role (server only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Resend (inquiry email notifications)
# https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxx"
# Verified sender in Resend (e.g. onboarding@resend.dev for testing, or your domain)
FROM_EMAIL="SuCai Cloud <notifications@sucaicloud.com>"
ADMIN_EMAIL="admin@sucaicloud.com"

# Optional: public site URL for canonical/OG (defaults to https://sucaicloud.com)
# NEXT_PUBLIC_SITE_URL="https://sucaicloud.com"

# Optional: dedicated admin session secret (recommended in production)
# ADMIN_SESSION_SECRET=your-random-secret

# Upstash Redis (rate limiting for public APIs — recommended in production)
# https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
